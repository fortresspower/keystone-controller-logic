  {
    "id": "d3f5f4c8d9b10004",
    "type": "function",
    "z": "d3f5f4c8d9b10001",
    "name": "Build Active Power Write",
    "func":"const value = Number(msg.payload);\nif (!Number.isFinite(value)) {\n  return [null, { payload: { error: 'invalid-active-power-value', value: msg.payload } }];\n}\n\nreturn [{\n  payload: {\n    cmd: 'write',\n    topic: 'PCS',\n    payload: [\n      {\n        tagID: 'SYSTEM_ACTIVE_POWER_DEMAND',\n        value\n      }\n    ]\n  }\n}, null];\n",
    "outputs": 2,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 260,
    "wires": [
      [
        "d3f5f4c8d9b10005"
      ],
      [
        "d3f5f4c8d9b10010"
      ]
    ]
  },
  {
    "id": "d3f5f4c8d9b10005",
    "type": "function",
    "z": "d3f5f4c8d9b10001",
    "name": "Writer Runtime",
    "func":"const lib = global.get('lib');\nif (!lib || !lib.writer || typeof lib.writer.handleWriterMessage !== 'function') {\n  node.status({ fill: 'red', shape: 'ring', text: 'writer API missing' });\n  return [null, null, { payload: { error: 'WRITER_API_MISSING' } }];\n}\n\nconst writer = lib.writer;\nconst state = flow.get('pcsWriterSmokeState') || writer.createWriterRuntimeState();\nconst incoming = msg.payload && typeof msg.payload === 'object' && !Array.isArray(msg.payload)\n  ? { ...msg, ...msg.payload }\n  : msg;\n\nconst asNodeRedMsg = (value) => {\n  if (value == null) return null;\n  if (typeof value === 'object' && !Array.isArray(value) && Object.prototype.hasOwnProperty.call(value, 'payload')) {\n    return value;\n  }\n  return { payload: value };\n};\n\nconst emittedWrites = [];\nconst envCfg = {\n  MODBUS_ZERO_BASED: false,\n  maxRegistersPerFrame: 120,\n  maxCoilsPerFrame: 120\n};\n\ntry {\n  const result = writer.handleWriterMessage(\n    incoming,\n    envCfg,\n    state,\n    (o1) => {\n      if (o1 != null) emittedWrites.push(asNodeRedMsg(o1));\n    }\n  );\n\n  flow.set('pcsWriterSmokeState', result.state);\n  node.status({ fill: 'green', shape: 'dot', text: incoming.cmd || 'write' });\n\n  return [\n    emittedWrites.length ? emittedWrites : null,\n    emittedWrites.length ? { payload: emittedWrites } : null,\n    asNodeRedMsg(result.out3)\n  ];\n} catch (err) {\n  node.status({ fill: 'red', shape: 'ring', text: 'runtime threw' });\n  return [null, null, { payload: { error: String(err) } }];\n}\n",
    "outputs": 3,
    "timeout": "",
    "noerr": 0,
