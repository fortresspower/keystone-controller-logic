    "protocol": "modbus-tcp",
    "defaultByteOrder": "BE",
    "defaultWordOrder32": "ABCD",
    "name": "udt_solarEdge_V1",
    "sourceFormat": "legacy-eGauge"
  },
  "telemetry": [
