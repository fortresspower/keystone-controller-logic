{
  "version": "2",
  "device": {
    "vendor": "Sinexcel",
    "model": "PVDC Module 1",
    "protocol": "modbus-tcp",
    "defaultByteOrder": "BE",
    "defaultWordOrder32": "ABCD",
    "name": "udt_Sinexcel_PVDC_Module1",
    "sourceFormat": "supplier-v119"
  },
