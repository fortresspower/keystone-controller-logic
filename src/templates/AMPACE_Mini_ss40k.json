    {
      "id": "batWarning",
      "description": "Calculated SS40K 40103 batWarning from AMPACE BAMS vendor fault words",
      "category": "Faults",
      "pollClass": "normal",
      "calc": {
        "inputs": {
          "p": "BamsProtAlarm0_8",
          "s": "BamsSysFaultCode0_8",
          "h": "BamsHwErrCode0_8",
          "msComm": "MsBamsCommState"
        },
        "expr": "(has(p, '0x00000f0000000000') << 1) | (((msComm !== 0 || hasAny(h, '0x00c0000000000000', '0x000000fc00000000', '0x00000000f0000000')) ? 1 : 0) << 2) | (has(p, '0x00000c0000000000') << 3) | (hasAny(p, '0x3300000000000000', '0x0000000000330000') << 4) | (hasAny(s, '0x0030000000000000', '0x00000c3f00000000') << 4) | (hasAny(p, '0x0c00000000000000', '0x0000000000cc0000') << 5) | (has(s, '0x0000030000000000') << 5) | (has(s, '0x000000c000000000') << 6)"
      },
      "alarm": true,
      "bitfieldStatus": true,
      "ss40k": {
        "name": "batWarning",
        "model": "40103"
      }
    },
    {
      "id": "batFault",
      "description": "Calculated SS40K 40103 batFault from AMPACE BAMS vendor fault words",
      "category": "Faults",
      "pollClass": "normal",
      "calc": {
        "inputs": {
          "p": "BamsProtAlarm0_8",
          "s": "BamsSysFaultCode0_8"
        },
        "expr": "hasAny(p, '0x0000c00000000000', '0x0000000000000033') | hasAny(s, '0x03c0000000000000', '0x0000c00000000000') | (hasAny(p, '0x00cc000000000000', '0x00000000000000cc') << 1) | (hasAny(s, '0x0000300000000000', '0x000000000c000000') << 1)"
      },
      "alarm": true,
      "bitfieldStatus": true,
      "ss40k": {
        "name": "batFault",
        "model": "40103"
      }
    },
