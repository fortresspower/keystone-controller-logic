      "function": "HRUS",
      "address": 9,
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "SbmuBatteryFault",
      "calc": {
        "inputs": {
          "w0": "WarningWord0400",
          "w1": "WarningWord0401",
          "w2": "WarningWord0402",
          "w3": "WarningWord0403",
          "w4": "WarningWord0404",
          "w5": "WarningWord0405",
          "w6": "WarningWord0406",
          "w7": "WarningWord0407",
          "w8": "WarningWord0408",
          "w9": "WarningWord0409"
        },
        "expr": "(w0 || w1 || w2 || w3 || w4 || w5 || w6 || w7 || w8 || w9) ? 1 : 0"
      },
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true,
      "ss40k": { "name": "BatteryFault", "model": "42103" }
    }
