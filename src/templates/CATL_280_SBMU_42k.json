      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "WarningWord0405",
      "description": "Subsystem warning/fault word 0x0405",
      "function": "HRUS",
      "address": 5,
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "WarningWord0406",
      "description": "Subsystem warning/fault word 0x0406",
      "function": "HRUS",
      "address": 6,
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "WarningWord0407",
      "description": "Subsystem warning/fault word 0x0407",
      "function": "HRUS",
      "address": 7,
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "WarningWord0408",
      "description": "Subsystem warning/fault word 0x0408",
      "function": "HRUS",
      "address": 8,
      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true
    },
    {
      "id": "WarningWord0409",
