      "address": 41,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 255, "engLow": -50, "engHigh": 205 },
      "ss40k": { "name": "ModTmpMin", "model": "42101" }
