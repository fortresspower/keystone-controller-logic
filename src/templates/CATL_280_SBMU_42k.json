      "pollClass": "slow",
      "alarm": true,
      "bitfieldStatus": true,
      "ss40k": { "name": "BatteryWarning1", "model": "42103" }
    },
    {
      "id": "WarningWord0401",
      "description": "Subsystem warning/fault word 0x0401",
