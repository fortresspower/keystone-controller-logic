      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 40000, "engLow": -2000, "engHigh": 2000 }
    },
    {
      "id": "MaxChargePowerAllowed",
      "description": "Max charge power allowed, register 0x042D",
      "function": "HRUS",
      "address": 45,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 40000, "engLow": -2000, "engHigh": 2000 }
    },
    {
      "id": "MaxDischargePowerAllowed",
      "description": "Max discharge power allowed, register 0x042E",
      "function": "HRUS",
      "address": 46,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 40000, "engLow": -2000, "engHigh": 2000 }
    },
    {
      "id": "BatterySubsystemPower",
      "description": "Battery subsystem power, register 0x042F",
      "function": "HRUS",
      "address": 47,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 40000, "engLow": -2000, "engHigh": 2000 },
      "ss40k": { "name": "W", "model": "42101", "exportMultiplier": 1000 }
    },
    {
      "id": "MaxCellVoltagePosition",
      "description": "Max cell voltage position, register 0x0430. Low byte is cell number, high byte is module number.",
      "function": "HRUS",
      "address": 48,
      "pollClass": "slow"
    },
    {
      "id": "MaxCellVoltageCellNumber",
      "calc": { "inputs": { "pos": "MaxCellVoltagePosition" }, "expr": "pos & 255" },
      "pollClass": "slow",
      "ss40k": { "name": "CellVMaxNCell", "model": "42101" }
    },
    {
      "id": "MinCellVoltagePosition",
      "description": "Min cell voltage position, register 0x0431. Low byte is cell number, high byte is module number.",
      "function": "HRUS",
      "address": 49,
      "pollClass": "slow"
    },
    {
      "id": "MinCellVoltageCellNumber",
      "calc": { "inputs": { "pos": "MinCellVoltagePosition" }, "expr": "pos & 255" },
      "pollClass": "slow",
      "ss40k": { "name": "CellVMinNCell", "model": "42101" }
    },
    {
      "id": "MaxCellTemperaturePosition",
      "description": "Max single cell temperature position, register 0x0432",
      "function": "HRUS",
      "address": 50,
      "pollClass": "slow",
      "ss40k": { "name": "ModTmpMaxN", "model": "42101" }
    },
    {
      "id": "MinCellTemperaturePosition",
