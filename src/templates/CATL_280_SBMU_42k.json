      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 1000, "engLow": 0, "engHigh": 100 }
    },
    {
      "id": "DischargeSOE",
      "description": "Discharge SOE, register 0x0435",
      "function": "HRUS",
      "address": 53,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 1000, "engLow": 0, "engHigh": 100 }
    },
    {
      "id": "RemainingChargeEnergy",
      "description": "Subsystem remaining charging energy, register 0x0436",
      "function": "HRUS",
      "address": 54,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 }
    },
    {
      "id": "RemainingDischargeEnergy",
      "description": "Subsystem remaining discharging energy, register 0x0437",
      "function": "HRUS",
      "address": 55,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 }
    },
    {
      "id": "SumOfCellVoltage",
      "description": "Sum of cell voltage, register 0x0438",
      "function": "HRUS",
      "address": 56,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 }
    },
    {
      "id": "PreChargeRelayStatus",
      "description": "Pre-charge relay status, register 0x0410",
      "function": "HRUS",
      "address": 16,
      "pollClass": "slow",
      "enumStatus": { "0": "Open", "1": "Close" },
      "statusFlag": true
    },
    {
      "id": "MasterPositiveRelayStatus",
      "description": "Master positive relay status, register 0x0411",
      "function": "HRUS",
      "address": 17,
      "pollClass": "slow",
      "enumStatus": { "0": "Open", "1": "Close" },
      "statusFlag": true
    },
    {
      "id": "MasterNegativeRelayStatus",
      "description": "Master negative relay status, register 0x0412",
      "function": "HRUS",
      "address": 18,
      "pollClass": "slow",
      "enumStatus": { "0": "Open", "1": "Close" },
      "statusFlag": true
    },
    {
      "id": "HighVoltageOnlineStatus",
      "description": "High voltage online status, register 0x0413",
      "function": "HRUS",
      "address": 19,
      "pollClass": "slow",
      "enumStatus": { "0": "Off", "1": "On" },
      "statusFlag": true
    },
    {
      "id": "SbmuStringStatus",
      "calc": { "inputs": { "hv": "HighVoltageOnlineStatus" }, "expr": "hv ? 1 : 0" },
      "pollClass": "slow",
      "ss40k": { "name": "St", "model": "42101" }
    },
    {
      "id": "SbmuChargeStatus",
      "calc": {
        "inputs": { "st": "SbmuStringStatus", "a": "BatterySubsystemCurrent" },
        "expr": "st === 0 ? 0 : (a < -1 ? 1 : (a > 1 ? 2 : 3))"
      },
      "pollClass": "slow",
      "ss40k": { "name": "ChaSt", "model": "42101" }
    },
    {
      "id": "SbmuContactorStatus",
      "calc": {
        "inputs": { "pos": "MasterPositiveRelayStatus", "neg": "MasterNegativeRelayStatus" },
        "expr": "(pos && neg) ? 3 : 0"
      },
      "pollClass": "slow",
      "ss40k": { "name": "ConSt", "model": "42101" }
    },
    {
      "id": "HistoricalCumulativeChargingEnergy",
      "description": "Historical cumulative charging energy, registers 0x0454-0x0455",
      "function": "HRUI",
      "address": 84,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 },
      "ss40k": { "name": "eBatChgTot", "model": "42101", "exportMultiplier": 1000 }
    },
    {
      "id": "HistoricalCumulativeDischargingEnergy",
      "description": "Historical cumulative discharging energy, registers 0x0456-0x0457",
      "function": "HRUI",
      "address": 86,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 },
      "ss40k": { "name": "eBatDischgTot", "model": "42101", "exportMultiplier": 1000 }
    },
    {
      "id": "HistoricalCycleCount",
      "description": "Historical cumulative charge/discharge cycle count, register 0x045C",
      "function": "HRUS",
      "address": 92,
      "pollClass": "slow",
      "ss40k": { "name": "Cycles", "model": "42101" }
    },
    {
      "id": "ProductionDateYear",
      "description": "Battery production date year, register 0x046C",
      "function": "HRUS",
      "address": 108,
      "pollClass": "startup"
    },
    {
      "id": "ProductionDateWeek",
      "description": "Battery production date week, register 0x046D",
      "function": "HRUS",
      "address": 109,
