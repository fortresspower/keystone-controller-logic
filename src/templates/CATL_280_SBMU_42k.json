      "address": 42,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 255, "engLow": -50, "engHigh": 205 }
    },
    {
      "id": "MaxAllowedChargeCurrent",
      "description": "Max allowed charge current, register 0x042B",
      "function": "HRUS",
      "address": 43,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 40000, "engLow": -2000, "engHigh": 2000 }
    },
    {
      "id": "MaxAllowedDischargeCurrent",
      "description": "Max allowed discharge current, register 0x042C",
