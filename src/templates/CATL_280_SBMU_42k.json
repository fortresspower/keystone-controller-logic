{
  "version": "2",
  "device": {
    "vendor": "CATL",
    "model": "EnerOne SBMU template",
    "protocol": "modbus-tcp",
    "defaultByteOrder": "BE",
    "defaultWordOrder32": "ABCD",
    "name": "CATL_280_SBMU_42k",
    "sourceFormat": "json-offset-template",
    "notes": "Addresses in this template are offsets from the SBMU base. Runtime base = 0x0400 + sbmuIndex * 0x0400."
  },
  "telemetry": [
    {
      "id": "Manufacturer",
      "constant": "CATL",
      "pollClass": "startup",
      "ss40k": { "name": "Mn", "model": "42100" }
    },
    {
      "id": "ProductModel",
      "constant": "eSpire280",
      "pollClass": "startup",
      "ss40k": { "name": "Md", "model": "42100" }
    },
    {
      "id": "SerialNumber",
      "constant": "${serialNumber}",
      "pollClass": "startup",
      "ss40k": { "name": "SN", "model": "42100" }
    },
    {
      "id": "BatterySubsystemVoltageOutside",
      "description": "Battery subsystem DC outside voltage, register 0x0420",
      "function": "HRUS",
      "address": 32,
      "pollClass": "slow",
      "scale": { "mode": "Linear", "rawLow": 0, "rawHigh": 10, "engLow": 0, "engHigh": 1 }
    },
